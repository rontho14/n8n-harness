# Copy to .env in repo root (never commit .env)
# Cursor MCP loads this via .cursor/mcp.json envFile.
# Restart Cursor after changing .env.

# n8n-cli (deploy, inspect, pull)
N8N_URL=https://your-instance.example.com
N8N_API_KEY=

# Local MCP (optional — base URL without /api/v1; often same host as N8N_URL)
N8N_API_URL=https://your-instance.example.com

# Optional MCP overrides (uncomment in .env if needed)
# MCP_LOG_LEVEL=error
# MCP_DISABLED_TOOLS=n8n_create_workflow,n8n_delete_workflow
