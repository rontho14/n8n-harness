{
  "mcpServers": {
    "n8n-harness-mcp": {
      "command": "node",
      "args": ["${workspaceFolder}/mcp/dist/mcp/index.js"],
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "NODE_DB_PATH": "${workspaceFolder}/mcp/data/nodes.db",
        "DISABLED_TOOLS": "n8n_create_workflow,n8n_update_full_workflow,n8n_update_partial_workflow,n8n_delete_workflow,n8n_test_workflow,n8n_manage_credentials,n8n_deploy_template,n8n_audit_instance"
      }
    }
  }
}


